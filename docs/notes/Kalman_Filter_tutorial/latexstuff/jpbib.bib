@Article{Dunn2006,
  Title                    = {The impact of photoreceptor noise on retinal gain controls.},
  Author                   = {Felice A. Dunn and Fred Rieke},
  Journal                  = {Curr Opin Neurobiol},
  Year                     = {2006},

  Month                    = {Aug},
  Number                   = {4},
  Pages                    = {363--370},
  Volume                   = {16},

  Abstract                 = {Multiple retinal mechanisms preserve visual sensitivity as the properties of the light inputs change. Rapid gain controls match the effective signaling range of retinal neurons to the local image statistics. Such gain controls trade an increased sensitivity for some aspects of the inputs for a decreased sensitivity to others. Rapid, local gain control comes at another cost: noise in the signal controlling gain (e.g. from the photoreceptors) will cause gain itself to vary even when the statistics of the light input are constant. Recent advances in identifying retinal pathways and the sites and mechanisms of mean and contrast adaptation have begun to clarify the tradeoffs associated with different gain control locations and how these tradeoffs differ for rod and cone vision.},
  Bdsk-url-1               = {http://dx.doi.org/10.1016/j.conb.2006.06.013},
  Doi                      = {10.1016/j.conb.2006.06.013},
  Institution              = {Program in Neurobiology and Behavior, University of Washington, Seattle, 98195, USA.},
  Keywords                 = {Adaptation, Physiological, physiology; Animals; Contrast Sensitivity, physiology; Humans; Neural Inhibition, physiology; Photoreceptor Cells, physiology; Retina, physiology; Synaptic Transmission, physiology; Vision, Ocular, physiology},
  Pii                      = {8(06)00090-0},
  Pmid                     = {16837189},
  Timestamp                = {2011.01.30},
  Url                      = {http://dx.doi.org/10.1016/j.conb.2006.06.013}
}

