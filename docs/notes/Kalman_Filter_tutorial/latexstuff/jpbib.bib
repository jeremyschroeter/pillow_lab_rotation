@Article{Darroch72,
  author              = {Darroch, J. N. and Ratcliff, D.},
  title               = {Generalized Iterative Scaling for Log-Linear Models},
  journal             = {The Annals of Mathematical Statistics},
  year                = {1972},
  volume              = {43},
  number              = {5},
  pages               = {pp. 1470-1480},
  issn                = {00034851},
  abstract            = {Say that a probability distribution {pi; i \in I} over a finite set I is in "product form" if (1) $p_i = \pi_i\mu \prod^d_{s=1} \mu_s^{b_si}$ where \pi_i and {bsi} are given constants and where \mu and {\mu_s} are determined from the equations (2) S_i \in I bsi pi = ks, s = 1, 2,..., d; (3) S_i ]in I pi = 1. Probability distributions in product form arise from minimizing the discriminatory information S_i \in I pi log pi/\pi_i subject to (2) and (3) or from maximizing entropy or maximizing likelihood. The theory of the iterative scaling method of determining (1) subject to (2) and (3) has, until now, been limited to the case when bsi = 0, 1. In this paper the method is generalized to allow the bsi to be any real numbers. This expands considerably the list of probability distributions in product form which it is possible to estimate by maximum likelihood.},
  bdsk-url-1          = {http://www.jstor.org/stable/2240069},
