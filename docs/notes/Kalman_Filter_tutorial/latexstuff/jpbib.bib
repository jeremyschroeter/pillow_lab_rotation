@Article{Bialek01,
  Title                    = {Predictability, complexity, and learning.},
  Author                   = {W. Bialek and I. Nemenman and N. Tishby},
  Journal                  = {Neural Comput},
  Year                     = {2001},

  Month                    = {Nov},
  Number                   = {11},
  Pages                    = {2409--2463},
  Volume                   = {13},

  Abstract                 = {We define predictive information I(pred)(T) as the mutual information between the past and the future of a time series. Three qualitatively different behaviors are found in the limit of large observation times T:I(pred)(T) can remain finite, grow logarithmically, or grow as a fractional power law. If the time series allows us to learn a model with a finite number of parameters, then I(pred)(T) grows logarithmically with a coefficient that counts the dimensionality of the model space. In contrast, power-law growth is associated, for example, with the learning of infinite parameter (or nonparametric) models such as continuous functions with smoothness constraints. There are connections between the predictive information and measures of complexity that have been defined both in learning theory and the analysis of physical systems through statistical mechanics and dynamical systems theory. Furthermore, in the same way that entropy provides the unique measure of available information consistent with some simple and plausible conditions, we argue that the divergent part of I(pred)(T) provides the unique measure for the complexity of dynamics underlying a time series. Finally, we discuss how these ideas may be useful in problems in physics, statistics, and biology.},
  Bdsk-url-1               = {http://dx.doi.org/10.1162/089976601753195969},
  Doi                      = {10.1162/089976601753195969},
  File                     = {Bialek01_Predictability_NC.pdf:Bialek01_Predictability_NC.pdf:PDF},
  Institution              = {NEC Research Institute, Princeton, NJ 08540, USA.},
  Keywords                 = {Forecasting; Humans; Information Theory; Learning, physiology; Models, Psychological},
  Pmid                     = {11674845},
  Url                      = {http://dx.doi.org/10.1162/089976601753195969}
}

@Article{Bialek92,
  Title                    = {Reliability and information transmission in spiking neurons},
  Author                   = {Bialek, W. and Rieke, F.},
  Journal                  = {Trends in Neurosciences},
  Year                     = {1992},
  Pages                    = {428--428},
  Volume                   = {15},

  Abstract                 = {Spiking neurons encode continuous, tim--varying signals in sequences of identical action potentials. Relatively simple algorithms allow one to 'decode' this neural representation of sensory data to estimate the input signals. Decoding experiments provide a quantitative characterization of information transmission and computational reliability under real-time conditions. The results of these studies show that neural coding and computation in several systems approach fundamental physical and informational theoretic limits to performance.},
  File                     = {Bialek92_Rieke_Reliability_TINS.pdf:Bialek92_Rieke_Reliability_TINS.pdf:PDF}
}

@Article{Bialek91,
  Title                    = {Reading a neural code},
  Author                   = {Bialek, W. and Rieke, F. and {de Ruyter van Steveninck}, R., R. R. and Warland, D.},
  Journal                  = {Science},
  Year                     = {1991},
  Pages                    = {1854--1857},
  Volume                   = {252},

  Abstract                 = {Traditional approaches to neural coding characterize the encoding of known stimuli in average neural responses. Organisms face nearly the opposite task--extracting information about an unknown time-dependent stimulus from short segments of a spike train. Here the neural code was characterized from the point of view of the organism, culminating in algorithms for real-time stimulus estimation based on a single example of the spike train. These methods were applied to an identified movement-sensitive neuron in the fly visual system. Such decoding experiments determined the effective noise level and fault tolerance of neural computation, and the structure of the decoding algorithms suggested a simple model for real-time analog signal processing with spiking neurons.},
  File                     = {Bialek91_ReadingNeurCode_Science.pdf:Bialek91_ReadingNeurCode_Science.pdf:PDF}
}

