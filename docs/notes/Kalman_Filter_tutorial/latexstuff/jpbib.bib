@Article{Chiao00,
  Title                    = {Color signals in natural scenes: characteristics of reflectance spectra and effects of natural illuminants},
  Author                   = {Chiao, C. C. and Cronin, T. W. and Osorio, D.},
  Journal                  = {Journal of the Optical Society of America A},
