@Article{Koyama10,
  Title                    = {Comparison of brain-computer interface decoding algorithms in open-loop and closed-loop control.},
  Author                   = {Shinsuke Koyama and Steven M. Chase and Andrew S. Whitford and Meel Velliste and Andrew B. Schwartz and Robert E. Kass},
  Journal                  = {J Comput Neurosci},
  Year                     = {2010},

  Month                    = {Aug},
  Number                   = {1-2},
  Pages                    = {73--87},
  Volume                   = {29},

  Abstract                 = {Neuroprosthetic devices such as a computer cursor can be controlled by the activity of cortical neurons when an appropriate algorithm is used to decode motor intention. Algorithms which have been proposed for this purpose range from the simple population vector algorithm (PVA) and optimal linear estimator (OLE) to various versions of Bayesian decoders. Although Bayesian decoders typically provide the most accurate off-line reconstructions, it is not known which model assumptions in these algorithms are critical for improving decoding performance. Furthermore, it is not necessarily true that improvements (or deficits) in off-line reconstruction will translate into improvements (or deficits) in on-line control, as the subject might compensate for the specifics of the decoder in use at the time. Here we show that by comparing the performance of nine decoders, assumptions about uniformly distributed preferred directions and the way the cursor trajectories are smoothed have the most impact on decoder performance in off-line reconstruction, while assumptions about tuning curve linearity and spike count variance play relatively minor roles. In on-line control, subjects compensate for directional biases caused by non-uniformly distributed preferred directions, leaving cursor smoothing differences as the largest single algorithmic difference driving decoder performance.},
  Bdsk-url-1               = {http://dx.doi.org/10.1007/s10827-009-0196-9},
  Doi                      = {10.1007/s10827-009-0196-9},
  Institution              = {Department of Statistics, Carnegie Mellon University, Pittsburgh, PA, USA. koyama@stat.cmu.edu},
  Pmid                     = {19904595},
  Timestamp                = {2010.10.17},
  Url                      = {http://dx.doi.org/10.1007/s10827-009-0196-9}
}

