@Article{Pouzat2002,
  Title                    = {Using noise signature to optimize spike-sorting and to assess neuronal classification quality.},
  Author                   = {Christophe Pouzat and Ofer Mazor and Gilles Laurent},
  Journal                  = {J Neurosci Methods},
  Year                     = {2002},

  Month                    = {Dec},
  Number                   = {1},
