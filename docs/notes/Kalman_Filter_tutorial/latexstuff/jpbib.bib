@Article{Kayser2004,
  Title                    = {Processing of complex stimuli and natural scenes in the visual cortex},
  Author                   = {Kayser, Christoph and K{\"o}rding, Konrad P and K{\"o}nig, Peter},
  Journal                  = {Curr Opin Neurobiol},
