@Article{Kafashan2020,
  author       = {Kafashan, Mohammad Mehdi and Jaffe, Anna and Chettih, Selmaan N. and Nogueira, Ramon and Arandia-Romero, I{\~n}igo and Harvey, Christopher D. and Moreno-Bote, Rub{\'e}n and Drugowitsch, Jan},
  title        = {Scaling of information in large neural populations reveals signatures of information-limiting correlations},
  journal      = {bioRxiv},
  year         = {2020},
  abstract     = {How is information distributed across large neuronal populations within a given brain area? One possibility is that information is distributed roughly evenly across neurons, so that total information scales linearly with the number of recorded neurons. Alternatively, the neural code might be highly redundant, meaning that total information saturates. Here we investigated how information about the direction of a moving visual stimulus is distributed across hundreds of simultaneously recorded neurons in mouse primary visual cortex (V1). We found that information scales sublinearly, due to the presence of correlated noise in these populations. Using recent theoretical advances, we compartmentalized noise correlations into information-limiting and nonlimiting components, and then extrapolated to predict how information grows when neural populations are even larger. We predict that tens of thousands of neurons are required to encode 95\% of the information about visual stimulus direction, a number much smaller than the number of neurons in V1. Overall, these findings suggest that the brain uses a widely distributed, but nonetheless redundant code that supports recovering most information from smaller subpopulations.},
  doi          = {10.1101/2020.01.10.902171},
  elocation-id = {2020.01.10.902171},
  eprint       = {https://www.biorxiv.org/content/early/2020/01/11/2020.01.10.902171.full.pdf},
  file         = {Kafashan2020_InfoScalingV1.pdf:Kafashan2020_InfoScalingV1.pdf:PDF},
  publisher    = {Cold Spring Harbor Laboratory},
  url          = {https://www.biorxiv.org/content/early/2020/01/11/2020.01.10.902171},
}

