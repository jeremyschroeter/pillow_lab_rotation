@Article{Sokoloski2021elife,
  author       = {Sokoloski, Sacha and Aschner, Amir and Coen-Cagli, Ruben},
  title        = {Modelling the neural code in large populations of correlated neurons},
  journal      = {eLife},
  year         = {2021},
  volume       = {10},
  pages        = {e64615},
  month        = {oct},
  issn         = {2050-084X},
  abstract     = {Neurons respond selectively to stimuli, and thereby define a code that associates stimuli with population response patterns. Certain correlations within population responses (noise correlations) significantly impact the information content of the code, especially in large populations. Understanding the neural code thus necessitates response models that quantify the coding properties of modelled populations, while fitting large-scale neural recordings and capturing noise correlations. In this paper, we propose a class of response model based on mixture models and exponential families. We show how to fit our models with expectation-maximization, and that they capture diverse variability and covariability in recordings of macaque primary visual cortex. We also show how they facilitate accurate Bayesian decoding, provide a closed-form expression for the Fisher information, and are compatible with theories of probabilistic population coding. Our framework could allow researchers to quantitatively validate the predictions of neural coding theories against both large-scale neural recordings and cognitive performance.},
  article_type = {journal},
  citation     = {eLife 2021;10:e64615},
  doi          = {10.7554/eLife.64615},
  editor       = {Pillow, Jonathan W and Gold, Joshua I and Harris, Kenneth D},
  keywords     = {primary visual cortex, neural coding, bayesian modelling},
  pub_date     = {2021-10-05},
  publisher    = {eLife Sciences Publications, Ltd},
  url          = {https://doi.org/10.7554/eLife.64615},
}

