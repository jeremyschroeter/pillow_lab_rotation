@Article{Pitkow15,
  author   = {Xaq Pitkow and Sheng Liu and DoraÂ E. Angelaki and GregoryÂ C. DeAngelis and Alexandre Pouget},
  journal  = {Neuron},
  title    = {How Can Single Sensory Neurons Predict Behavior?},
  year     = {2015},
  issn     = {0896-6273},
  number   = {2},
  pages    = {411 - 423},
  volume   = {87},
  abstract = {Summary Single sensory neurons can be surprisingly predictive of behavior in discrimination tasks. We propose this isÂ possible because sensory information extracted from neural populations is severely restricted, either by near-optimal decoding of a population with information-limiting correlations or by suboptimal decoding that is blind to correlations. These have different consequences for choice correlations, the correlations between neural responses and behavioral choices. In the vestibular and cerebellar nuclei and the dorsal medial superior temporal area, we found that choice correlations during heading discrimination are consistent with near-optimal decoding ofÂ neuronal responses corrupted by information-limiting correlations. In the ventral intraparietal area, the choice correlations are also consistent with the presence of information-limiting correlations, but this area does not appear to influence behavior, although the choice correlations are particularly large. These findings demonstrate how choice correlations can be used to assess the efficiency of the downstream readout and detect the presence of information-limiting correlations.},
  doi      = {http://dx.doi.org/10.1016/j.neuron.2015.06.033},
  file     = {Pitkow15_Neuron_SingNeurBehavior.pdf:Pitkow15_Neuron_SingNeurBehavior.pdf:PDF},
  url      = {http://www.sciencedirect.com/science/article/pii/S0896627315005966},
}

