  File                     = {Huys09_SmoothingIntracellData.pdf:Huys09_SmoothingIntracellData.pdf:PDF},
  Publisher                = {Public Library of Science},
  Url                      = {http://dx.doi.org/10.1371%2Fjournal.pcbi.1000379}
}

