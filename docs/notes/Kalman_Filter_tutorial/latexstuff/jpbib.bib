@Article{Kennel05,
  author      = {Matthew B. Kennel and Jonathon Shlens and Henry D. I. Abarbanel and E. J. Chichilnisky},
  title       = {Estimating entropy rates with Bayesian confidence intervals.},
  journal     = {Neural Comput},
  year        = {2005},
  volume      = {17},
  number      = {7},
  pages       = {1531--1576},
  month       = {Jul},
  abstract    = {The entropy rate quantifies the amount of uncertainty or disorder produced by any dynamical system. In a spiking neuron, this uncertainty translates into the amount of information potentially encoded and thus the subject of intense theoretical and experimental investigation. Estimating this quantity in observed, experimental data is difficult and requires a judicious selection of probabilistic models, balancing between two opposing biases. We use a model weighting principle originally developed for lossless data compression, following the minimum description length principle. This weighting yields a direct estimator of the entropy rate, which, compared to existing methods, exhibits significantly less bias and converges faster in simulation. With Monte Carlo techinques, we estimate a Bayesian confidence interval for the entropy rate. In related work, we apply these ideas to estimate the information rates between sensory stimuli and neural responses in experimental data (Shlens, Kennel, Abarbanel, & Chichilnisky, in preparation).},
  bdsk-url-1  = {http://dx.doi.org/10.1162/0899766053723050},
  comment     = {Notes: - defines estimator using context trees - eq. 2.6 first line is wrong - bizarre bit about what to do with deterministic data - (in general, their articulation of Bayesian approach is a bit strange) - use MCMC to find credible intervals (instead of using formula for posterior variance).},
  doi         = {10.1162/0899766053723050},
  file        = {Kennel05_NC_EntropyRates.pdf:Kennel05_NC_EntropyRates.pdf:PDF},
  institution = {Institute for Nonlinear Science, University of California, San Diego, La Jolla, CA 92093-0402, USA. mkennel@ucsd.edu},
  keywords    = {Bayes Theorem; Confidence Intervals; Entropy; Statistics as Topic},
  pmid        = {15901407},
  timestamp   = {2011.04.20},
  url         = {http://dx.doi.org/10.1162/0899766053723050},
}

