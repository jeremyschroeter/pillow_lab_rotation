@Article{Brainard06,
  Title                    = {Bayesian model of human color constancy},
  Author                   = {Brainard, David H. and Longere, Philippe and Delahunt, Peter B. and Freeman, William T. and Kraft, James M. and Xiao, Bei},
  Journal                  = {J. Vis.},
  Year                     = {2006},

  Month                    = {11},
  Number                   = {11},
  Pages                    = {1267-1281},
  Volume                   = {6},

  Abstract                 = {Vision is difficult because images are ambiguous about the structure of the world. For object color, the ambiguity arises because the same object reflects a different spectrum to the eye under different illuminations. Human vision typically does a good job of resolving this ambiguity--an ability known as color constancy. The past 20 years have seen an explosion of work on color constancy, with advances in both experimental methods and computational algorithms. Here, we connect these two lines of research by developing a quantitative model of human color constancy. The model includes an explicit link between psychophysical data and illuminant estimates obtained via a Bayesian algorithm. The model is fit to the data through a parameterization of the prior distribution of illuminant spectral properties. The fit to the data is good, and the derived prior provides a succinct description of human performance.},
  Bdsk-url-1               = {http://journalofvision.org/6/11/10/},
  Eprint                   = {http://journalofvision.org/6/11/10/Brainard-2006-jov-6-11-10.pdf},
  File                     = {Brainard06_JOV_BayesColorConstancy.pdf:Brainard06_JOV_BayesColorConstancy.pdf:PDF},
  ISSN                     = {1534-7362},
  Keywords                 = {color constancy, psychophysical data, illuminants, Bayesian algorithm, computational neuroscience},
  Url                      = {http://journalofvision.org/6/11/10/}
}

