  Journal                  = {Vision Res},
  Year                     = {2007},

  Month                    = {Oct},
  Number                   = {22},
  Pages                    = {2868--2877},
  Volume                   = {47},

  Abstract                 = {The selectivities of neurons in primary visual cortex are often considered to be adapted to the statistics of natural images. Accordingly, simple cell-like tuning emerges when unsupervised learning models that seek sparse representations of input probabilities are trained on natural scenes. However, orientation tuning develops before structured vision starts, rendering these previous results moot as models of activity-dependent development. A more stringent examination of such models comes from experiments demonstrating altered neural response properties in goggle-reared kittens. We show that an unsupervised learning model of cortical responsivity accounts well for the dramatic effects of stimulus driven development during goggle-rearing.},
  Bdsk-url-1               = {http://dx.doi.org/10.1016/j.visres.2007.07.023},
