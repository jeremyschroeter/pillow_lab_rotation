@Article{Driscoll2022currop,
  author   = {Laura N. Driscoll and Lea Duncker and Christopher D. Harvey},
  title    = {Representational drift: Emerging theories for continual learning and experimental future directions},
  journal  = {Current Opinion in Neurobiology},
  year     = {2022},
  volume   = {76},
  pages    = {102609},
  issn     = {0959-4388},
  abstract = {Recent work has revealed that the neural activity patterns correlated with sensation, cognition, and action often are not stable and instead undergo large scale changes over days and weeks--a phenomenon called representational drift. Here, we highlight recent observations of drift, how drift is unlikely to be explained by experimental confounds, and how the brain can likely compensate for drift to allow stable computation. We propose that drift might have important roles in neural computation to allow continual learning, both for separating and relating memories that occur at distinct times. Finally, we present an outlook on future experimental directions that are needed to further characterize drift and to test emerging theories for drift's role in computation.},
  doi      = {https://doi.org/10.1016/j.conb.2022.102609},
  file     = {Driscoll2022currop.pdf:Driscoll2022currop.pdf:PDF},
  url      = {https://www.sciencedirect.com/science/article/pii/S0959438822001039},
}

