  Doi                      = {10.1038/nn2007},
  File                     = {Kable07_Glimcher.pdf:Kable07_Glimcher.pdf:PDF},
  Institution              = {Center for Neural Science, New York University, 4 Washington Place, Room 809, New York, New York 10003, USA.},
  Keywords                 = {Adult; Brain Mapping; Brain, anatomy /&/ histology/blood supply/physiology; Decision Making, physiology; Female; Humans; Image Processing, Computer-Assisted, methods; Magnetic Resonance Imaging; Male; Oxygen, blood; Psychometrics, methods; Reinforcement Schedule; Reward; Time Factors},
