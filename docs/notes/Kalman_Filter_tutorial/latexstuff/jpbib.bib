@Article{Gauthier2009a,
  Title                    = {Receptive fields in primate retina are coordinated to sample visual space more uniformly.},
  Author                   = {Jeffrey L. Gauthier and Greg D. Field and Alexander Sher and Martin Greschner and Jonathon Shlens and Alan M. Litke and E. J. Chichilnisky},
  Journal                  = {PLoS Biol},
  Year                     = {2009},

  Month                    = {Apr},
  Number                   = {4},
  Pages                    = {e1000063},
  Volume                   = {7},

  Abstract                 = {In the visual system, large ensembles of neurons collectively sample visual space with receptive fields (RFs). A puzzling problem is how neural ensembles provide a uniform, high-resolution visual representation in spite of irregularities in the RFs of individual cells. This problem was approached by simultaneously mapping the RFs of hundreds of primate retinal ganglion cells. As observed in previous studies, RFs exhibited irregular shapes that deviated from standard Gaussian models. Surprisingly, these irregularities were coordinated at a fine spatial scale: RFs interlocked with their neighbors, filling in gaps and avoiding large variations in overlap. RF shapes were coordinated with high spatial precision: the observed uniformity was degraded by angular perturbations as small as 15 degrees, and the observed populations sampled visual space with more than 50\% of the theoretical ideal uniformity. These results show that the primate retina encodes light with an exquisitely coordinated array of RF shapes, illustrating a higher degree of functional precision in the neural circuitry than previously appreciated.},
  Bdsk-url-1               = {http://dx.doi.org/371/journal.pbio.1000063},
  Doi                      = {371/journal.pbio.1000063},
  Institution              = {Salk Institute for Biological Studies, La Jolla, California, United States of America. gauthier@salk.edu},
  Keywords                 = {Animals; Brain Mapping; Nerve Net, cytology/physiology; Primates; Retina, cytology/physiology; Retinal Ganglion Cells, cytology/physiology; Vision, Ocular, physiology; Visual Fields, physiology; Visual Pathways, cytology/physiology; Visual Perception, physiology},
  Pii                      = {08-PLBI-RA-0586},
  Pmid                     = {19355787},
  Timestamp                = {2010.09.22},
  Url                      = {http://dx.doi.org/371/journal.pbio.1000063}
}

@Article{Gauthier2009,
  Title                    = {Uniform signal redundancy of parasol and midget ganglion cells in primate retina.},
  Author                   = {Jeffrey L. Gauthier and Greg D. Field and Alexander Sher and Jonathon Shlens and Martin Greschner and Alan M. Litke and E. J. Chichilnisky},
  Journal                  = {J Neurosci},
  Year                     = {2009},

  Month                    = {Apr},
  Number                   = {14},
  Pages                    = {4675--4680},
  Volume                   = {29},

  Abstract                 = {The collective representation of visual space in high resolution visual pathways was explored by simultaneously measuring the receptive fields of hundreds of ON and OFF midget and parasol ganglion cells in isolated primate retina. As expected, the receptive fields of all four cell types formed regular mosaics uniformly tiling the visual scene. Surprisingly, comparison of all four mosaics revealed that the overlap of neighboring receptive fields was nearly identical, for both the excitatory center and inhibitory surround components of the receptive field. These observations contrast sharply with the large differences in the dendritic overlap between the parasol and midget cell populations, revealing a surprising lack of correspondence between the anatomical and functional architecture in the dominant circuits of the primate retina.},
  Bdsk-url-1               = {http://dx.doi.org/10.1523/JNEUROSCI.5294-08.2009},
  Doi                      = {10.1523/JNEUROSCI.5294-08.2009},
  Institution              = {Salk Institute for Biological Studies, 10010 NorthTorrey Pines Road, La Jolla, CA 92037, USA.},
  Keywords                 = {Action Potentials, physiology; Animals; Macaca fascicularis; Macaca mulatta; Retinal Ganglion Cells, cytology/physiology; Signal Transduction, physiology},
  Pii                      = {29/14/4675},
  Pmid                     = {19357292},
  Timestamp                = {2010.09.22},
  Url                      = {http://dx.doi.org/10.1523/JNEUROSCI.5294-08.2009}
}

