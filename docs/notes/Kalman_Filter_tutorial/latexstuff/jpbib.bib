@Article{Gu2011,
  Title                    = {Perceptual learning reduces interneuronal correlations in macaque visual cortex.},
  Author                   = {Yong Gu and Sheng Liu and Christopher R Fetsch and Yun Yang and Sam Fok and Adhira Sunkara and Gregory C DeAngelis and Dora E Angelaki},
  Journal                  = {Neuron},
  Year                     = {2011},

  Month                    = {Aug},
  Number                   = {4},
  Pages                    = {750--761},
  Volume                   = {71},

  Abstract                 = {Responses of neurons in early visual cortex change little with training and appear insufficient to account for perceptual learning. Behavioral performance, however, relies on population activity, and the accuracy of a population code is constrained by correlated noise among neurons. We tested whether training changes interneuronal correlations in the dorsal medial superior temporal area, which is involved in multisensory heading perception. Pairs of single units were recorded simultaneously in two groups of subjects: animals trained extensively in a heading discrimination task, and "naive" animals that performed a passive fixation task. Correlated noise was significantly weaker in trained versus naive animals, which might be expected to improve coding efficiency. However, we show that the observed uniform reduction in noise correlations leads to little change in population coding efficiency when all neurons are decoded. Thus, global changes in correlated noise among sensory neurons may be insufficient to account for perceptual learning.},
  Bdsk-url-1               = {http://dx.doi.org/10.1016/j.neuron.2011.06.015},
  Doi                      = {10.1016/j.neuron.2011.06.015},
  Institution              = {Department of Anatomy and Neurobiology, Washington University School of Medicine, St. Louis, MO 63110, USA.},
  Keywords                 = {Animals; Discrimination (Psychology), physiology; Electrophysiology; Interneurons, cytology/physiology; Learning, physiology; Macaca mulatta; Male; Models, Neurological; Perception, physiology; Visual Cortex, cytology/physiology},
  Pii                      = {S0896-6273(11)00543-5},
  Pmid                     = {21867889},
  Url                      = {http://dx.doi.org/10.1016/j.neuron.2011.06.015}
}

